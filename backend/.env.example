# HagerStone Backend - Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=4000

# Supabase
SUPABASE_URL=https://vosbhngbnodisoiianhk.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Secret - copy from Supabase Dashboard → Settings → API → JWT Secret
JWT_SECRET=your_jwt_secret_here

# Google Vision API - path to service account JSON file (relative to backend root)
GOOGLE_APPLICATION_CREDENTIALS=./config/service-account.json
VISION_PROJECT_ID=hagerstone-expense-vision

# File Upload
MAX_FILE_SIZE_MB=10

# CORS - comma-separated (add Expo web and your PC IP for mobile testing)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8081

# AI Verification Thresholds
CONFIDENCE_AUTO_APPROVE=94
CONFIDENCE_MANUAL_REVIEW=70
AMOUNT_TOLERANCE_INR=10
DATE_TOLERANCE_DAYS=2
