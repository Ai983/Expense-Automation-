{
  "expo": {
    "name": "HagerStone Expenses",
    "slug": "hagerstone-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hagerstone",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hagerstone.expenses"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.hagerstone.expenses",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HagerStone to upload payment receipts from your gallery.",
          "cameraPermission": "Allow HagerStone to capture payment receipts."
        }
      ],
      "expo-secure-store"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "experiments": {
      "typedRoutes": false
    }
  }
}
